{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["**", "!**/__fixtures__"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/prompt-kit/**", "**/components/ui/**"],
			"linter": {
				"domains": {
					"next": "none",
					"react": "none"
				},
				"rules": {
					"recommended": false,
					"suspicious": {
						"noArrayIndexKey": "off"
					},
					"security": {
						"noDangerouslySetInnerHtml": "off"
					},
					"performance": {
						"noImgElement": "off"
					},
					"correctness": {
						"useExhaustiveDependencies": "off"
					}
				}
			}
		}
	]
}
